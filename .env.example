# Copy file này thành .env và điền giá trị thực
# cp .env.example .env

# ===========================================================================
# CASE 1: Dùng OpenAI API (mặc định, cần API key, VECTOR_SIZE=1536)
# ===========================================================================
# OPENAI_API_KEY=sk-your-openai-api-key-here
# EMBED_ENABLED=true
# EMBED_PROVIDER=openai
# VECTOR_SIZE=1536

# ===========================================================================
# CASE 2: Dùng local embedding (offline, không cần API key, VECTOR_SIZE=384)
# Cài đặt trước: pip install sentence-transformers torch
# ===========================================================================
# EMBED_ENABLED=true
# EMBED_PROVIDER=local
# EMBED_LOCAL_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# VECTOR_SIZE=384

# ===========================================================================
# CASE 3: Tắt embedding hoàn toàn (chạy thử pipeline, không gọi LLM)
# ===========================================================================
# EMBED_ENABLED=false
# VECTOR_SIZE=1536

# ===========================================================================
# Cấu hình chung (chọn 1 case ở trên rồi giữ nguyên phần này)
# ===========================================================================

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-api-key-here

# === Embedding (uncomment case phù hợp ở trên, mặc định: openai) ===
EMBED_ENABLED=true
EMBED_PROVIDER=openai
EMBED_LOCAL_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Rate limit protection (chi anh huong OpenAI provider):
#   EMBED_BATCH_DELAY : delay co dinh (giay) giua moi batch (mac dinh 0.5s)
#   EMBED_MAX_RETRIES : so lan retry khi gap 429 (mac dinh 3)
#   EMBED_BACKOFF_FACTOR: he so nhan cho moi lan retry (mac dinh 2.0 -> 1s, 2s, 4s)
EMBED_BATCH_DELAY=0.5
EMBED_MAX_RETRIES=3
EMBED_BACKOFF_FACTOR=2.0

# === Qdrant ===
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=conversation_memory
# VECTOR_SIZE phai khop voi model dang dung:
#   openai text-embedding-3-small -> 1536
#   paraphrase-multilingual-MiniLM-L12-v2 (local) -> 384
VECTOR_SIZE=1536
TOP_K=5

# === Data Files (relative hoặc absolute path) ===
CRM_FILE=data-train/crm_customer_book_revenue_20260418.csv
CHAT_FILE=data-train/raw_message_convertation_20260418.xlsx

# === Scoring ===
SCORE_THRESHOLD=70

# === Top Sales ===
TOP_SALES_PERCENTILE=0.3

# === Chunking ===
MAX_TURNS_PER_CHUNK=10
MIN_TURNS_PER_CHUNK=3
